  "definitions": {
    "MarketplaceId": {
      "description": "The unobfuscated marketplace identifier.",
      "type": "string"
    },
    "ConfirmShipmentRequest": {
      "type": "object",
      "required": ["marketplaceId", "packageDetail"],
      "properties": {
        "packageDetail": {
          "$ref": "#/definitions/PackageDetail"
        },
        "codCollectionMethod": {
          "type": "string",
          "description": "The COD collection method (only supported in the JP marketplace).",
          "enum": ["DirectPayment"]
        },
        "marketplaceId": {
          "$ref": "#/definitions/MarketplaceId"
        }
      },
      "description": "The request schema for an shipment confirmation."
    },
    "ConfirmShipmentErrorResponse": {
      "type": "object",
